{
  "name": "kenzik-resume-web",
  "version": "1.0.1",
  "description": "Terminal-based resume web application",
  "scripts": {
    "dev": "quasar dev",
    "build": "quasar build -m pwa",
    "lint": "eslint --ext .js,.ts,.vue src",
    "format": "prettier --write \"src/**/*.{js,ts,vue,json,css,scss,md}\"",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:e2e:offline": "playwright test --config playwright.offline.config.ts"
  },
  "dependencies": {
    "@quasar/extras": "^1.16.9",
    "ifvms": "^1.1.6",
    "js-yaml": "^4.1.0",
    "marked": "^11.1.1",
    "quasar": "^2.14.2",
    "vue": "^3.4.15",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@quasar/app-vite": "^1.4.0",
    "@types/js-yaml": "^4.0.9",
    "@types/marked": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitest/ui": "^4.1.8",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.20.0",
    "happy-dom": "^20.10.2",
    "prettier": "^3.2.4",
    "typescript": "~5.3.3",
    "vitest": "^4.1.8",
    "workbox-build": "7.0.x",
    "workbox-cacheable-response": "7.0.x",
    "workbox-core": "7.0.x",
    "workbox-expiration": "7.0.x",
    "workbox-precaching": "7.0.x",
    "workbox-routing": "7.0.x",
    "workbox-strategies": "7.0.x"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=9.0.0",
    "yarn": ">=1.22.0"
  }
}
