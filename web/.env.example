# Resume Contact Information
# These variables are injected at build time via Vite
# Copy this file to .env.local and fill in your values

# Your display name
VITE_RESUME_NAME="Your Name"

# Your location (City, State format)
VITE_RESUME_CITY_STATE="City, State"

# LinkedIn profile URL (without https://)
VITE_RESUME_LINKEDIN="linkedin.com/in/username"

# GitHub profile URL (without https://)
VITE_RESUME_GITHUB="github.com/username"
