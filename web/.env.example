# Resume Environment Variables
# Copy this file to .env.local and fill in your real data

# Your name
VITE_RESUME_NAME="Your Name"

# Contact information (will be redacted by default in terminal)
VITE_RESUME_CITY_STATE="City, State"
VITE_RESUME_PHONE="+1 123-123-1234"
VITE_RESUME_EMAIL="your.email@example.com"
VITE_RESUME_LINKEDIN="https://linkedin.com/in/yourprofile"

# Optional: Path to YAML file (default: /kenzik.yml from public folder)
# VITE_RESUME_YAML_PATH="/kenzik.yml"

